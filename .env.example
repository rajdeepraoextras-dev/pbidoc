# Copy to .env and fill in what you need — nothing here is required to run
# PBICompass locally with the offline (deterministic) engine. See DEPLOYMENT.md
# for how these apply in production.

# -- Web service -------------------------------------------------------------

# Require an API key on every request (multi-tenant / hosted mode).
# Unset or "0" = open "public" tenant, no auth, no quota (self-hosted default).
PBICOMPASS_REQUIRE_AUTH=0

# Accounts + per-day usage counts (never report metadata). A plain path is a
# SQLite file — point at a persistent volume in production, e.g.
# /data/pbicompass.db. For managed Postgres (survives redeploy without a
# volume, and the only way two instances can share one accounts DB), use a
# postgres:// or postgresql:// URL instead and install the extra:
#   pip install "pbicompass[postgres]"
#   PBICOMPASS_DB=postgresql://user:password@host:5432/pbicompass
PBICOMPASS_DB=pbicompass.db

# SQLite path for job status + rendered-output bytes (TTL-swept). Point at the
# same persistent volume as PBICOMPASS_DB so an in-flight/finished job survives
# a restart instead of 404ing on the next status poll (A2-1).
PBICOMPASS_JOBS_DB=pbicompass_jobs.db

# Async worker (optional — pip install "pbicompass[queue]"). Default "inline"
# runs jobs via FastAPI BackgroundTasks in the same process; "celery" enqueues
# onto Celery + Redis instead (removes Cloud Run's CPU-throttling failure
# class — see DEPLOYMENT.md). Requires a file-backed PBICOMPASS_JOBS_DB.
PBICOMPASS_QUEUE=inline
PBICOMPASS_BROKER_URL=redis://localhost:6379/0
# PBICOMPASS_RESULT_BACKEND=   # defaults to PBICOMPASS_BROKER_URL

# Per-IP rate limit on POST /jobs (Day 20) — independent of and ahead of the
# per-plan daily quota, so it also protects an unauthenticated "public"
# deployment. Requests beyond the limit get a 429.
PBICOMPASS_UPLOAD_RATE_LIMIT=20
PBICOMPASS_UPLOAD_RATE_WINDOW_SECONDS=60

# -- User accounts / sessions (Day 21) ---------------------------------------
# Signup/login create a server-side session (an opaque, hashed cookie token,
# same reasoning as an API key) plus a separate CSRF cookie for the
# double-submit check on state-changing session-authenticated requests
# (POST /auth/logout today). Only active once PBICOMPASS_DB is actually
# configured (see above) — same as the admin panel.

# How long a session (and its cookie) stays valid, in seconds. Default 30 days.
PBICOMPASS_SESSION_TTL_SECONDS=2592000

# Session/CSRF cookies are Secure (HTTPS-only) by default, matching every
# deployment option in DEPLOYMENT.md, which puts TLS in front of the app.
# Set to "0" ONLY for a plain http local-dev session -- never in production.
PBICOMPASS_COOKIE_SECURE=1

# Per-IP rate limit on POST /auth/* (signup/login/logout/verify/reset) -- a
# separate budget from the upload limiter above, since auth abuse and upload
# abuse are different threats.
PBICOMPASS_AUTH_RATE_LIMIT=10
PBICOMPASS_AUTH_RATE_WINDOW_SECONDS=60

# -- Transactional email: verification + password reset (Day 22) -------------
# Backend for the verify/reset emails. "console" (default) just LOGS the link
# so the whole flow works on a bare self-host with no provider -- read the
# link out of the logs. "smtp" sends for real via any provider's SMTP
# interface (Resend / Postmark / Amazon SES / ...), using stdlib smtplib (no
# new dependency). Emails only ever contain an auth link + the recipient's
# own address -- never report data.
PBICOMPASS_EMAIL_BACKEND=console

# Base URL the emailed links point at, e.g. https://docs.example.com. Unset =
# links degrade to a bare path (still usable via the console backend in dev).
PBICOMPASS_PUBLIC_URL=

# SMTP settings (only used when PBICOMPASS_EMAIL_BACKEND=smtp). Get these from
# your transactional provider's SMTP credentials page.
PBICOMPASS_SMTP_HOST=
PBICOMPASS_SMTP_PORT=587
PBICOMPASS_SMTP_USER=
PBICOMPASS_SMTP_PASSWORD=
PBICOMPASS_SMTP_FROM=
PBICOMPASS_SMTP_TLS=1

# Require a verified email before a user can log in. Off by default so a fresh
# self-host isn't locked out before an email provider is configured; turn on
# for a hosted SaaS. When on, an unverified login is refused (403) and a fresh
# verification link is re-sent.
PBICOMPASS_REQUIRE_EMAIL_VERIFICATION=0

# -- "Sign in with Microsoft" — Entra ID OIDC (Day 23) -----------------------
# All three of client id/secret and a resolvable redirect URI must be set to
# enable it; otherwise the /auth/oidc/* routes report 404 (feature absent) and
# nothing new is imported. Register an app in the Azure portal (Entra ID > App
# registrations), add a Web redirect URI of <your-url>/auth/oidc/callback, and
# create a client secret. Standard OIDC auth-code + PKCE flow, zero new deps.
PBICOMPASS_OIDC_CLIENT_ID=
PBICOMPASS_OIDC_CLIENT_SECRET=
# Tenant: a specific tenant GUID (single-tenant, strictest), or one of
# "common" / "organizations" / "consumers" (multi-tenant). Default: common.
PBICOMPASS_OIDC_TENANT=common
# Redirect URI registered on the app. If unset, it's derived from
# PBICOMPASS_PUBLIC_URL + /auth/oidc/callback (so setting PBICOMPASS_PUBLIC_URL
# is usually enough).
PBICOMPASS_OIDC_REDIRECT_URI=

# Per-job working directory. Point at a tmpfs (RAM) mount in production for
# strict zero-retention (uploads never touch a physical disk).
PBICOMPASS_SANDBOX_ROOT=

# Max upload size, in MB.
PBICOMPASS_MAX_UPLOAD_MB=100

# Watchdog: force-fail a job stuck in "processing" longer than this many
# seconds (protects against a hung LLM call or slow render on a large file).
PBICOMPASS_JOB_TIMEOUT_SECONDS=600

# Structured JSON logs (timestamp/level/logger/message/request_id/job_id) to
# stdout. Never includes report content or raw exception text — only an
# exception's type name (matching the rest of this app's content-free
# logging convention).
PBICOMPASS_LOG_LEVEL=INFO

# Sentry error tracking (optional — pip install "pbicompass[observability]").
# Unset = disabled (default). PII, local variables, and source-code context
# are all off by construction; exception messages are scrubbed to just
# their type name before being sent.
SENTRY_DSN=
# Free-text label shown on Sentry events (e.g. "staging", "production").
PBICOMPASS_ENV=production

# Admin panel (/admin): lets an operator create, list, and revoke API keys
# from the browser instead of shelling into the container. Set a long random
# secret to enable it — unset means the panel is disabled (503 on every
# /admin/api/* call). Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Setting this alone (without PBICOMPASS_REQUIRE_AUTH) lets you provision
# accounts ahead of time; /jobs stays open until you also flip auth on.
PBICOMPASS_ADMIN_TOKEN=

# -- AI engines (optional — pip install -e ".[agents]") ----------------------
# Only needed if you want AI-written prose instead of the offline engine.
# Leave both unset to run fully offline; callers can also BYOK per-request
# via the web UI's "API key" field instead of setting these server-side.

ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# GOOGLE_API_KEY=   # alternate name Gemini also reads
COHERE_API_KEY=
# CO_API_KEY=       # alternate name Cohere also reads
